<Project Sdk="Microsoft.NET.Sdk">

    <PropertyGroup>
        <OutputType>WinExe</OutputType>
        <TargetFramework>net10.0-windows</TargetFramework>
        <Nullable>enable</Nullable>
        <ImplicitUsings>enable</ImplicitUsings>
        <UseWPF>true</UseWPF>
    </PropertyGroup>

    <ItemGroup>
        <!-- HelixToolkit.Wpf 2.25.0 ships as net4x but is binary-compatible with
             net10.0-windows WPF. Suppress NU1701 until a native .NET build ships. -->
        <PackageReference Include="HelixToolkit.Wpf" Version="2.25.0" NoWarn="NU1701" />
    </ItemGroup>

</Project>
