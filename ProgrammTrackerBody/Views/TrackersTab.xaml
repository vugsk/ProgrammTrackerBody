<UserControl x:Class="ProgrammTrackerBody.Views.TrackersTab"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:viewmodels="clr-namespace:ProgrammTrackerBody.ViewModels"
             mc:Ignorable="d"
             d:DesignHeight="600" d:DesignWidth="900">
    <Grid>
        <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="16">
            <ItemsControl ItemsSource="{Binding TrackerViewModels}" x:Name="TrackersList">
                <ItemsControl.ItemTemplate>
                    <DataTemplate DataType="{x:Type viewmodels:TrackerViewModel}">
                        <Border BorderBrush="#CCCCCC" BorderThickness="1" CornerRadius="6" Padding="12" Margin="0,0,0,10" Background="#FAFAFA">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>

                                <!-- Header: name + status -->
                                <StackPanel Grid.Row="0" Grid.Column="0" Orientation="Horizontal">
                                    <TextBlock Text="{DynamicResource Trackers.DisplayName}" Margin="0,0,8,0" VerticalAlignment="Center" />
                                    <TextBox Text="{Binding Model.DisplayName, UpdateSourceTrigger=LostFocus}" Width="200" />
                                    <TextBlock Text="{DynamicResource Trackers.Mac}" Margin="20,0,8,0" VerticalAlignment="Center" />
                                    <TextBlock Text="{Binding Model.Mac}" FontFamily="Consolas" VerticalAlignment="Center" />
                                </StackPanel>

                                <Border Grid.Row="0" Grid.Column="1"
                                        Background="{Binding StatusBrush}"
                                        CornerRadius="3" Padding="8,2">
                                    <TextBlock Text="{Binding StatusTextKey, Converter={StaticResource ResourceLookupConverter}}"
                                               Foreground="White" FontWeight="SemiBold" />
                                </Border>

                                <!-- Body part + mounting -->
                                <StackPanel Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2" Orientation="Horizontal" Margin="0,12,0,0">
                                    <TextBlock Text="{DynamicResource Trackers.BodyPart}" Margin="0,0,8,0" VerticalAlignment="Center" />
                                    <ComboBox ItemsSource="{Binding AvailableBodyParts}"
                                              SelectedItem="{Binding Model.BodyPart, Mode=TwoWay}"
                                              MinWidth="160">
                                        <ComboBox.ItemTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding ., Converter={StaticResource EnumResourceLookupConverter}, ConverterParameter=BodyPart}" />
                                            </DataTemplate>
                                        </ComboBox.ItemTemplate>
                                    </ComboBox>

                                    <TextBlock Text="{DynamicResource Trackers.Mounting}" Margin="20,0,8,0" VerticalAlignment="Center" />
                                    <ComboBox ItemsSource="{StaticResource AllMountings}"
                                              SelectedItem="{Binding Model.MountingOrientation, Mode=TwoWay}"
                                              MinWidth="120">
                                        <ComboBox.ItemTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding ., Converter={StaticResource EnumResourceLookupConverter}, ConverterParameter=Mounting}" />
                                            </DataTemplate>
                                        </ComboBox.ItemTemplate>
                                    </ComboBox>

                                    <CheckBox Content="{DynamicResource Calibration.DiagLog}"
                                              IsChecked="{Binding Model.LogRawAndDisplay, Mode=TwoWay}"
                                              VerticalAlignment="Center" Margin="20,0,0,0" />
                                </StackPanel>

                                <!-- Battery / RSSI / Rotation -->
                                <UniformGrid Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="2" Columns="3" Margin="0,12,0,0">
                                    <StackPanel>
                                        <TextBlock Text="{DynamicResource Trackers.Battery}" FontWeight="SemiBold" />
                                        <TextBlock>
                                            <Run Text="{Binding Model.BatteryPercentage, StringFormat={}{0:F1}%}" />
                                            <Run Text=" (" />
                                            <Run Text="{Binding Model.BatteryVoltage, StringFormat={}{0:F2}V}" />
                                            <Run Text=")" />
                                        </TextBlock>
                                    </StackPanel>
                                    <StackPanel>
                                        <TextBlock Text="{DynamicResource Trackers.Rssi}" FontWeight="SemiBold" />
                                        <TextBlock Text="{Binding Model.Rssi}" />
                                    </StackPanel>
                                    <StackPanel>
                                        <TextBlock Text="{DynamicResource Trackers.Rotation}" FontWeight="SemiBold" />
                                        <TextBlock Text="{Binding Model.DisplayRotationText}" FontFamily="Consolas" />
                                    </StackPanel>
                                </UniformGrid>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <TextBlock Text="{DynamicResource Trackers.Empty}"
                   HorizontalAlignment="Center" VerticalAlignment="Center"
                   Foreground="#888888" FontStyle="Italic"
                   Visibility="{Binding TrackerViewModels.Count, Converter={StaticResource ZeroToVisibleConverter}}" />
    </Grid>
</UserControl>
