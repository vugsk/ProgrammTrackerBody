<UserControl x:Class="ProgrammTrackerBody.Views.DashboardTab"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignHeight="600" d:DesignWidth="900">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,12">
            <TextBlock Text="{DynamicResource Dashboard.Port}" VerticalAlignment="Center" Margin="0,0,8,0" />
            <TextBox Text="{Binding PortText, UpdateSourceTrigger=PropertyChanged}" Width="80" VerticalContentAlignment="Center" />
            <Button Content="{Binding StartStopButtonKey, Converter={StaticResource ResourceLookupConverter}}"
                    Command="{Binding StartStopCommand}"
                    Margin="12,0,0,0" Padding="12,4" />
            <Button Content="{DynamicResource Dashboard.Broadcast}"
                    Command="{Binding BroadcastCommand}"
                    Margin="8,0,0,0" Padding="12,4" />
        </StackPanel>

        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,12">
            <TextBlock Text="{DynamicResource Dashboard.Status}" Margin="0,0,8,0" VerticalAlignment="Center" />
            <TextBlock Text="{Binding SessionStateKey, Converter={StaticResource ResourceLookupConverter}}"
                       FontWeight="SemiBold" VerticalAlignment="Center" Margin="0,0,24,0" />
            <TextBlock Text="{DynamicResource Dashboard.ConnectedTrackers}" VerticalAlignment="Center" Margin="0,0,8,0" />
            <TextBlock Text="{Binding ConnectedCount}" FontWeight="SemiBold" VerticalAlignment="Center" />
        </StackPanel>

        <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,0,0,12">
            <TextBlock Text="{DynamicResource Dashboard.Language}" VerticalAlignment="Center" Margin="0,0,8,0" />
            <Button Content="{DynamicResource Dashboard.LanguageRu}"
                    Command="{Binding SetLanguageCommand}" CommandParameter="ru"
                    Margin="0,0,8,0" Padding="12,4" />
            <Button Content="{DynamicResource Dashboard.LanguageEn}"
                    Command="{Binding SetLanguageCommand}" CommandParameter="en"
                    Padding="12,4" />
        </StackPanel>
    </Grid>
</UserControl>
