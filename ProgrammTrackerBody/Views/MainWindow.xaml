<Window x:Class="ProgrammTrackerBody.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:views="clr-namespace:ProgrammTrackerBody.Views"
        mc:Ignorable="d"
        Title="{DynamicResource App.Title}"
        Height="720" Width="1100">
    <TabControl>
        <TabItem Header="{DynamicResource Tab.Dashboard}">
            <views:DashboardTab DataContext="{Binding Dashboard}" />
        </TabItem>
        <TabItem Header="{DynamicResource Tab.Trackers}">
            <views:TrackersTab DataContext="{Binding Trackers}" />
        </TabItem>
        <TabItem Header="{DynamicResource Tab.Calibration}">
            <views:CalibrationTab DataContext="{Binding Calibration}" />
        </TabItem>
        <TabItem Header="{DynamicResource Tab.Skeleton}">
            <views:SkeletonTab DataContext="{Binding Skeleton}" />
        </TabItem>
        <TabItem Header="{DynamicResource Tab.Logs}">
            <views:LogsTab DataContext="{Binding Logs}" />
        </TabItem>
    </TabControl>
</Window>
