    <!-- Calibration tab -->
    <sys:String x:Key="Calibration.YawReset">Сброс Yaw</sys:String>
    <sys:String x:Key="Calibration.FullReset">Полный сброс</sys:String>
    <sys:String x:Key="Calibration.MountingReset">Сброс ориентации</sys:String>
    <sys:String x:Key="Calibration.Vibrate">Вибрация</sys:String>
