    <sys:String x:Key="Mounting.Front">Спереди</sys:String>
    <sys:String x:Key="Mounting.Back">Сзади</sys:String>
    <sys:String x:Key="Mounting.Left">Слева</sys:String>
    <sys:String x:Key="Mounting.Right">Справа</sys:String>

</ResourceDictionary>
