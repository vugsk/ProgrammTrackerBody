    <sys:String x:Key="BodyPart.Chest">Грудь</sys:String>
    <sys:String x:Key="BodyPart.Waist">Талия</sys:String>
    <sys:String x:Key="BodyPart.Hip">Таз</sys:String>
    <sys:String x:Key="BodyPart.LeftUpperLeg">Левое бедро</sys:String>
