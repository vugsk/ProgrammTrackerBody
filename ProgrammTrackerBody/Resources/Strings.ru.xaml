    <sys:String x:Key="BodyPart.LeftLowerLeg">Левая голень</sys:String>
    <sys:String x:Key="BodyPart.RightLowerLeg">Правая голень</sys:String>
    <sys:String x:Key="BodyPart.LeftFoot">Левая стопа</sys:String>
    <sys:String x:Key="BodyPart.RightFoot">Правая стопа</sys:String>
    <sys:String x:Key="BodyPart.LeftUpperArm">Левое плечо</sys:String>
    <sys:String x:Key="BodyPart.RightUpperArm">Правое плечо</sys:String>
