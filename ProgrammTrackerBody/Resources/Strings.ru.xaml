    <sys:String x:Key="Tab.Calibration">Калибровка</sys:String>
    <sys:String x:Key="Tab.Skeleton">Скелет</sys:String>
    <sys:String x:Key="Tab.Logs">Журналы</sys:String>

    <!-- Dashboard -->
    <sys:String x:Key="Dashboard.Port">Порт:</sys:String>
    <sys:String x:Key="Dashboard.Start">Запустить сервер</sys:String>
    <sys:String x:Key="Dashboard.Stop">Остановить сервер</sys:String>
    <sys:String x:Key="Dashboard.Broadcast">Отправить handshake</sys:String>
    <sys:String x:Key="Dashboard.Status">Статус:</sys:String>
    <sys:String x:Key="Dashboard.ConnectedTrackers">Подключено трекеров:</sys:String>
    <sys:String x:Key="Dashboard.Language">Язык:</sys:String>
    <sys:String x:Key="Dashboard.LanguageRu">Русский</sys:String>
    <sys:String x:Key="Dashboard.LanguageEn">English</sys:String>

    <!-- State labels -->
    <sys:String x:Key="State.Stopped">Остановлен</sys:String>
    <sys:String x:Key="State.Discovery">Поиск</sys:String>
    <sys:String x:Key="State.SessionStart">Начало сессии</sys:String>
    <sys:String x:Key="State.Streaming">Поток данных</sys:String>

    <!-- Trackers tab -->
    <sys:String x:Key="Trackers.Empty">Нет подключённых трекеров. Запустите сервер на панели.</sys:String>
    <sys:String x:Key="Trackers.DisplayName">Имя</sys:String>
    <sys:String x:Key="Trackers.Mac">MAC</sys:String>
    <sys:String x:Key="Trackers.BodyPart">Часть тела</sys:String>
    <sys:String x:Key="Trackers.Mounting">Ориентация</sys:String>
    <sys:String x:Key="Trackers.Battery">Батарея</sys:String>
    <sys:String x:Key="Trackers.Rssi">RSSI</sys:String>
