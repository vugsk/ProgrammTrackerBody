    <sys:String x:Key="BodyPart.RightLowerArm">Правое предплечье</sys:String>
    <sys:String x:Key="BodyPart.LeftHand">Левая кисть</sys:String>
    <sys:String x:Key="BodyPart.RightHand">Правая кисть</sys:String>

