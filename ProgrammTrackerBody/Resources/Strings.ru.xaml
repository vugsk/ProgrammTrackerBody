    <sys:String x:Key="Skeleton.Height">Рост:</sys:String>
    <sys:String x:Key="Skeleton.Cm">см</sys:String>
    <sys:String x:Key="Skeleton.NoTrackers">Назначьте части тела трекерам на вкладке «Трекеры».</sys:String>
    <sys:String x:Key="Skeleton.ShowAxes">Показать оси трекеров</sys:String>

